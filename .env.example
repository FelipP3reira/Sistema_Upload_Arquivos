# Copie para .env e ajuste o que precisar.
NODE_ENV=development
PORT=3336
BASE_URL=http://localhost:3336

# Postgres do docker-compose deste repositório.
DATABASE_URL=postgresql://upload:upload@localhost:5436/upload?schema=public

# Segredo das URLs assinadas (>= 32 caracteres). Troque em produção.
ASSINATURA_SECRET=desenvolvimento-troque-isto-por-um-segredo-grande

# Limite de tamanho por arquivo, em bytes (padrão 25 MB).
TAMANHO_MAX_BYTES=26214400

# Storage: 'local' (filesystem, padrão em dev) ou 's3' (MinIO/S3).
STORAGE_DRIVER=local
STORAGE_DIR=./dados-upload

# Preencha só se STORAGE_DRIVER=s3 (MinIO do docker-compose):
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=us-east-1
# S3_BUCKET=uploads
# S3_ACCESS_KEY=upload
# S3_SECRET_KEY=uploadsecret
